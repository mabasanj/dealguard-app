{
  "name": "dealguard-backend",
  "version": "1.0.0",
  "description": "Express backend API for DealGuard - South African fintech for informal trading",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:stable": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "smoke:backend": "powershell -ExecutionPolicy Bypass -File ./smoke-backend.ps1",
    "smoke:stellar": "powershell -ExecutionPolicy Bypass -File ./smoke-stellar.ps1",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "escrow",
    "fintech",
    "south-africa",
    "express",
    "typescript",
    "prisma"
  ],
  "author": "DealGuard",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.0.1",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5",
    "stellar-sdk": "^8.2.3",
    "stripe": "^15.10.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
