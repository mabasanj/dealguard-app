# Backend API
NEXT_PUBLIC_API_URL="/api"
BACKEND_API_URL="http://localhost:5000/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:5000"

# Database (Next.js API routes if needed)
DATABASE_URL="postgresql://user:password@localhost:5432/escrow_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Local payment rails
NEXT_PUBLIC_DEFAULT_CARD_PROVIDER="peach"
NEXT_PUBLIC_DEFAULT_BANK_PROVIDER="stitch"
NEXT_PUBLIC_DEFAULT_CRYPTO_BRIDGE="zarp"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_KEY"
STRIPE_SECRET_KEY="sk_test_YOUR_KEY"
STITCH_API_KEY="stitch_test_YOUR_KEY"
PEACH_ACCESS_TOKEN="peach_test_YOUR_KEY"
ZARP_SEP24_URL="https://anchor.zarp.com/sep24"

# Stellar / Soroban Mainnet
STELLAR_HORIZON_URL="https://horizon.stellar.org"
STELLAR_RPC_URL="https://mainnet.sorobanrpc.com"
STELLAR_NETWORK="PUBLIC"
SOROBAN_ESCROW_CONTRACT_ID="your-soroban-contract-id"

# Email Service
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-password"

# App Settings
NEXT_PUBLIC_APP_NAME="DealGuard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="dealguard.app"
NODE_ENV="development"
