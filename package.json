{
  "name": "dealguard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:merged": "concurrently -n frontend,backend -c cyan,green \"npm:dev\" \"npm --prefix backend run dev:stable\"",
    "build": "next build",
    "build:all": "npm run build && npm --prefix backend run build",
    "soroban:doctor": "powershell -ExecutionPolicy Bypass -File ./soroban/scripts/doctor.ps1",
    "soroban:build": "cargo build --manifest-path soroban/Cargo.toml --workspace --target wasm32v1-none --release",
    "soroban:build:ci": "cargo build --manifest-path soroban/Cargo.toml --workspace --target wasm32v1-none --release --jobs 4",
    "soroban:test": "cargo test --manifest-path soroban/Cargo.toml --workspace",
    "start": "next start",
    "start:merged": "concurrently -n frontend,backend -c cyan,green \"npm:start\" \"npm --prefix backend run start\"",
    "lint": "next lint",
    "smoke:integration": "powershell -ExecutionPolicy Bypass -File ./smoke-integration.ps1",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.0.1",
    "@stellar/freighter-api": "^6.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.15",
    "next-auth": "^4.24.12",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "socket.io-client": "^4.8.3",
    "stripe": "^15.10.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.3.3",
    "zod": "^3.23.8",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.1.3",
    "prisma": "^6.0.1"
  }
}
